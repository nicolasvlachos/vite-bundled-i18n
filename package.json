{
  "name": "vite-bundled-i18n",
  "private": false,
  "version": "0.6.1",
  "description": "Route-aware i18n bundler for Vite. Translations are AST-extracted, tree-shaken per page, and shipped as scope-matched bundles — not loaded globally.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "author": "Nicolas Vlachos",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicolasvlachos/vite-bundled-i18n.git"
  },
  "homepage": "https://github.com/nicolasvlachos/vite-bundled-i18n#readme",
  "bugs": {
    "url": "https://github.com/nicolasvlachos/vite-bundled-i18n/issues"
  },
  "keywords": [
    "i18n",
    "vite",
    "react",
    "translations",
    "localization",
    "typescript"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "tinyglobby": "^0.2.16"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "vite-bundled-i18n": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./vanilla": {
      "types": "./dist/vanilla.d.ts",
      "default": "./dist/vanilla.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "default": "./dist/vue.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    },
    "./generated": {
      "types": "./dist/core/i18n-generated.d.ts",
      "default": "./dist/core/i18n-generated-shim.js"
    }
  },
  "scripts": {
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.types.json && node scripts/postbuild-lib.mjs",
    "build": "npm run build:lib",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "i18n": "tsx src/cli/index.ts",
    "prepublishOnly": "npm run lint && npm test && npm run build:lib"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4",
    "vue": "^3.5.32"
  }
}
